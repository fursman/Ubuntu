#!/bin/bash
# Lock screen with blurred desktop background (fast)

TMPIMG="/tmp/lockscreen-bg.png"

# Downscale to 1/4, blur (much faster), then upscale back
grim -t png -s 0.25 "$TMPIMG" && \
    convert "$TMPIMG" -blur 0x4 -resize 400% -brightness-contrast -5x-5 "$TMPIMG"

# gtklock with Dracula-themed style and blurred background
gtklock -d -s ~/.config/gtklock/style.css -b "$TMPIMG" -H -T 5
